#import "../components/style.typ": *

#let Glossario(
) = [

  #hide[
    = Glossário
  ]

  #v(-.5cm)

  #box(fill: rgb("EAEAEA50"), inset: (x: .75cm, top: .75cm, bottom: .6cm))[

    #set par(leading: 1em, spacing: 2em)

    #text(size: sizeBodySmall, tracking: 0pt)[
      #strong[Orçamento Originário:] Despesas empenhadas por meio da utilização dos créditos orçamentários originalmente reservados às IFES na Lei Orçamentária Anual (LOA).

      #strong[Resultado Lei:] Uma das formas de classificação do orçamento da IFES. O objetivo é identificar os valores executados oriundos do orçamento Obrigatório (com baixa ou nenhuma flexibilidade de aplicação por parte da IFES, geralmente folha de pagamentos de pessoal); Discricionário (maior flexibilidade de aplicação por parte da IFES, geralmente gastos com manutenção e investimentos) e Emendas (recursos adicionais destinados pelo Legislativo Federal para aplicação na IFES).

      #strong[Grupo Despesa:] Outra forma de classificação do orçamento da IFES. O objetivo é identificar os montantes executados com despesas de Pessoal/Encargos (basicamente referentes aos Vencimentos (Pessoal Ativo), Proventos (Pessoal Inativo) e Encargos Previdenciários), Custeio (basicamente gastos com a manutenção da IFES: Vigilância, Limpeza, Diárias, Auxílio Financeiro a Estudantes/Pesquisadores, etc.) e Capital (basicamente gastos com Investimentos: Aquisições de Máquinas, Equipamentos, Obras, Veículos, etc.).

      #strong[Crédito Recebido por Destaque:] Também chamado de Crédito Descentralizado Recebido, corresponde aos recursos recebidos pelas IFES oriundos de outros órgãos (geralmente relacionados a Termos de Execução Descentralizada (TED) e créditos para pagamentos de Encargos de Cursos e Concursos – GECC).

      #strong[Auxílios Financeiros a Estudantes e Pesquisadores:] São recursos destinados pela IFES ao pagamento de Bolsas e Ajudas de Custos da CAPES a estudantes e pesquisadores.

      #strong[Orçamento Originário:] Despesas empenhadas por meio da utilização dos créditos orçamentários originalmente reservados às IFES na Lei Orçamentária Anual (LOA).

      #strong[Resultado Lei:] Uma das formas de classificação do orçamento da IFES. O objetivo é identificar os valores executados oriundos do orçamento Obrigatório (com baixa ou nenhuma flexibilidade de aplicação por parte da IFES, geralmente folha de pagamentos de pessoal); Discricionário (maior flexibilidade de aplicação por parte da IFES, geralmente gastos com manutenção e investimentos) e Emendas (recursos adicionais destinados pelo Legislativo Federal para aplicação na IFES).

      #strong[Grupo Despesa:] Outra forma de classificação do orçamento da IFES. O objetivo é identificar os montantes executados com despesas de Pessoal/Encargos (basicamente referentes aos Vencimentos (Pessoal Ativo), Proventos (Pessoal Inativo) e Encargos Previdenciários), Custeio (basicamente gastos com a manutenção da IFES: Vigilância, Limpeza, Diárias, Auxílio Financeiro a Estudantes/Pesquisadores, etc.) e Capital (basicamente gastos com Investimentos: Aquisições de Máquinas, Equipamentos, Obras, Veículos, etc.).

      #strong[Crédito Recebido por Destaque:] Também chamado de Crédito Descentralizado Recebido, corresponde aos recursos recebidos pelas IFES oriundos de outros órgãos (geralmente relacionados a Termos de Execução Descentralizada (TED) e créditos para pagamentos de Encargos de Cursos e Concursos – GECC).
    ]
  ]



  


