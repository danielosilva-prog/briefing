# School Report Docker Environment Configuration

# Environment
ENVIRONMENT=development
DEBUG=true

# PostgreSQL
POSTGRES_USER=schoolreport
POSTGRES_PASSWORD=schoolreport
POSTGRES_DB=schoolreport

# Redis
REDIS_URL=redis://redis:6379/0

# Google Cloud Platform
GCP_PROJECT_ID=your-project-id
GCS_BUCKET=your-bucket-name

# Path to GCP credentials file on host machine
GCP_CREDENTIALS_PATH=./credentials

# Worker configuration
WORKER_CONCURRENCY=10
WORKER_REPLICAS=1
